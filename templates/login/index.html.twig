{% extends 'base.html.twig' %}

{% block body %}
    <div class="container my-5">
        <h1>Connexion</h1>
        {% if error %}
        {#  pour les msg d'erreur  #}
        <div>{{error.messageKey|trans(error.messageData,'security')}}</div>
        {% endif %}
        {#  je met le nom de la route pour me permet  de rediriger le user apres soummission form #}
        <form action="{{path('app_login')}}" method='post'>
            <label for="username">Votre email</label>

            <input class="form-control" type="text" id="username" name="_username" 
            value="{{last_username}}"/>

            <label for="password">Votre mot de passe</label>

            <input class="form-control" type="password" id="password" name="_password" />

            <input type="hidden"  name="_target_path" value="{{path("app_account")}}" />

            <button type="submit" class="btn btn-success mt-3">Se connecter</button>
        </form>
        <br>
        {#  si pas de compte rediriger vers inscription #}
        Vous n'avez pas de compte ? <a href="{{path('app_register')}}">Inscrivez-Vous<a/>
    </div>
{% endblock %}
